// Compound assignment test: +=, -=, *=, /=, %=
fun main() {
    // +=
    var x = 10
    x += 5
    print(x)  // 15

    // -=
    var y = 20
    y -= 7
    print(y)  // 13

    // *=
    var z = 3
    z *= 4
    print(z)  // 12

    // /=
    var w = 100
    w /= 3
    print(w)  // 33

    // %=
    var m = 17
    m %= 5
    print(m)  // 2
}
