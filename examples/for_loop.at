// For loop test: condition and infinite loops
fun main() {
    // Condition loop: for i < 5 { print(i); i = i + 1 }
    var i = 0
    for i < 5 {
        print(i)
        i = i + 1
    }

    // Infinite loop with break
    var j = 10
    for {
        when j == 12 { break else print(j) }
        j = j + 1
    }
}
