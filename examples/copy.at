// Copy expression: creates a shallow copy of a value
fun main() {
    // Copy of basic types (no-op, values are already copied)
    val a = 42
    val b = copy a
    print(b)  // 42

    // Copy of a struct
    val point = {x = 10, y = 20}
    val p2 = copy point
    print(p2.x)  // 10
    print(p2.y)  // 20
}
